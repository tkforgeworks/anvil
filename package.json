{
  "name": "anvil",
  "productName": "Anvil",
  "version": "0.1.2-rc.7",
  "description": "RPG Data Management Tool",
  "author": "TKForgeWorks",
  "repository": {
    "type": "git",
    "url": "https://github.com/tkforgeworks/anvil.git"
  },
  "license": "UNLICENSED",
  "homepage": "https://www.tkforgeworks.com",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-forge package",
    "make": "electron-vite build && electron-forge make",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "test": "node scripts/test.js",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags",
    "rc:patch": "node scripts/rc-tag.js patch",
    "rc:minor": "node scripts/rc-tag.js minor",
    "rc:major": "node scripts/rc-tag.js major"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^6.1.6",
    "@mui/material": "^6.1.6",
    "better-sqlite3": "^12.9.0",
    "nunjucks": "^3.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-deb": "^7.5.0",
    "@electron-forge/maker-rpm": "^7.5.0",
    "@reforged/maker-appimage": "^5.2.0",
    "@electron-forge/maker-squirrel": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "@electron-forge/shared-types": "^7.5.0",
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/nunjucks": "^3.2.6",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^41.2.0",
    "electron-vite": "^5.0.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.4"
  }
}
